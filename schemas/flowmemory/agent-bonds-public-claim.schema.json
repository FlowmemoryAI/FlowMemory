{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "flowmemory.agent_bonds_public_claim.v1",
  "title": "Agent Bonds Public Claim V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "claimLevel",
    "enabled",
    "headline",
    "shortClaim",
    "longClaim",
    "allowedClaims",
    "disallowedClaims",
    "substantiation",
    "blockers",
    "generatedAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "agent-bonds-public-claim/v1"
    },
    "claimLevel": {
      "enum": [
        "internal_dev",
        "capped_pilot",
        "integration_beta",
        "public_protocol_available",
        "broad_public_launch"
      ]
    },
    "enabled": {
      "type": "boolean"
    },
    "headline": {
      "type": "string"
    },
    "shortClaim": {
      "type": "string"
    },
    "longClaim": {
      "type": "string"
    },
    "allowedClaims": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "disallowedClaims": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "substantiation": {
      "type": "object"
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "generatedAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "$defs": {
    "hex32": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{64}$"
    },
    "address": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{40}$"
    },
    "uintString": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)$"
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "uri": {
      "type": "string",
      "minLength": 1
    }
  }
}
