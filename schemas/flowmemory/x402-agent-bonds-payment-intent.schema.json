{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "flowmemory.x402_agent_bonds_payment_intent.v1",
  "title": "x402 Agent Bonds Payment Intent V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "paymentIntentId",
    "mode",
    "network",
    "asset",
    "amount",
    "payTo",
    "description",
    "x402",
    "status",
    "timestamps"
  ],
  "properties": {
    "schemaVersion": {
      "const": "x402-agent-bonds-payment-intent/v1"
    },
    "paymentIntentId": {
      "type": "string"
    },
    "mode": {
      "enum": [
        "service_payment",
        "escrow_bridge"
      ]
    },
    "envelopeId": {
      "type": "string"
    },
    "envelopeHash": {
      "$ref": "#/$defs/hex32"
    },
    "network": {
      "type": "object",
      "required": [
        "chainId",
        "caip2"
      ],
      "properties": {
        "chainId": {
          "type": "integer"
        },
        "caip2": {
          "type": "string"
        }
      }
    },
    "asset": {
      "type": "object",
      "required": [
        "address",
        "symbol",
        "decimals"
      ],
      "properties": {
        "address": {
          "$ref": "#/$defs/address"
        },
        "symbol": {
          "type": "string"
        },
        "decimals": {
          "type": "integer"
        }
      }
    },
    "amount": {
      "type": "object",
      "required": [
        "atomic",
        "display",
        "currency"
      ],
      "properties": {
        "atomic": {
          "$ref": "#/$defs/uintString"
        },
        "display": {
          "type": "string"
        },
        "currency": {
          "type": "string"
        }
      }
    },
    "payTo": {
      "$ref": "#/$defs/address"
    },
    "description": {
      "type": "string"
    },
    "x402": {
      "type": "object",
      "additionalProperties": true
    },
    "status": {
      "enum": [
        "created",
        "payment_required",
        "payment_submitted",
        "settled",
        "linked_to_escrow",
        "failed",
        "expired"
      ]
    },
    "timestamps": {
      "type": "object",
      "required": [
        "createdAt",
        "expiresAt"
      ],
      "properties": {
        "createdAt": {
          "$ref": "#/$defs/dateTime"
        },
        "expiresAt": {
          "$ref": "#/$defs/dateTime"
        },
        "updatedAt": {
          "$ref": "#/$defs/dateTime"
        }
      }
    }
  },
  "$defs": {
    "hex32": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{64}$"
    },
    "address": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{40}$"
    },
    "uintString": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)$"
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "uri": {
      "type": "string",
      "minLength": 1
    }
  }
}
