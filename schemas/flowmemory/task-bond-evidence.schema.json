{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "flowmemory.task_bond_evidence.v1",
  "title": "FlowMemory TaskBond Evidence V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "taskId",
    "submittedBy",
    "evidenceCommitment",
    "artifactCommitment",
    "availabilityCommitment",
    "availabilityUntil",
    "evidenceURI",
    "submittedAt",
    "checks"
  ],
  "properties": {
    "schema": { "const": "flowmemory.task_bond_evidence.v1" },
    "taskId": { "$ref": "#/$defs/hex32" },
    "submittedBy": { "$ref": "#/$defs/address" },
    "evidenceCommitment": { "$ref": "#/$defs/hex32" },
    "artifactCommitment": { "$ref": "#/$defs/hex32" },
    "availabilityCommitment": { "$ref": "#/$defs/hex32" },
    "availabilityUntil": { "type": "string", "format": "date-time" },
    "evidenceURI": { "type": "string", "minLength": 1 },
    "submittedAt": { "type": "string", "format": "date-time" },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "passed"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "passed": { "type": "boolean" },
          "detail": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "hex32": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" },
    "address": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" }
  }
}
