{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "flowmemory.task_bond_availability_proof.v1",
  "title": "FlowMemory TaskBond AvailabilityProof V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "taskId",
    "availabilityCommitment",
    "providerId",
    "retentionPolicyHash",
    "availabilitySampleRoot",
    "availableUntil",
    "evidenceURI",
    "status",
    "checks"
  ],
  "properties": {
    "schema": { "const": "flowmemory.task_bond_availability_proof.v1" },
    "taskId": { "$ref": "#/$defs/hex32" },
    "availabilityCommitment": { "$ref": "#/$defs/hex32" },
    "providerId": { "$ref": "#/$defs/hex32" },
    "retentionPolicyHash": { "$ref": "#/$defs/hex32" },
    "availabilitySampleRoot": { "$ref": "#/$defs/hex32" },
    "availableUntil": { "type": "string", "format": "date-time" },
    "evidenceURI": { "type": "string", "minLength": 1 },
    "status": { "enum": ["available", "degraded", "expired"] },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "passed"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "passed": { "type": "boolean" },
          "detail": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "hex32": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" }
  }
}
