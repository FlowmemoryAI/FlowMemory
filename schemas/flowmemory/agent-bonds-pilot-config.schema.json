{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "flowmemory.agent_bonds_pilot_config.v1",
  "title": "FlowMemory Agent Bonds Pilot Config V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "network",
    "contracts",
    "roles",
    "caps",
    "policy",
    "custody",
    "docs"
  ],
  "properties": {
    "schema": { "const": "flowmemory.agent_bonds_pilot_config.v1" },
    "network": {
      "type": "object",
      "additionalProperties": false,
      "required": ["chainId", "networkName"],
      "properties": {
        "chainId": { "type": "integer", "minimum": 1 },
        "networkName": { "type": "string", "minLength": 1 }
      }
    },
    "contracts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["settlementToken", "stakeToken", "escrow", "stakeRegistry", "policyRegistry", "manager", "multisig"],
      "properties": {
        "settlementToken": { "$ref": "#/$defs/address" },
        "stakeToken": { "$ref": "#/$defs/address" },
        "escrow": { "$ref": "#/$defs/address" },
        "stakeRegistry": { "$ref": "#/$defs/address" },
        "policyRegistry": { "$ref": "#/$defs/address" },
        "manager": { "$ref": "#/$defs/address" },
        "multisig": { "$ref": "#/$defs/address" }
      }
    },
    "roles": {
      "type": "object",
      "additionalProperties": false,
      "required": ["multisigOwners", "threshold", "pauseGuardian", "resolutionAuthority", "requesters", "agents", "verifiers", "confirmingVerifiers"],
      "properties": {
        "multisigOwners": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/address" }
        },
        "threshold": { "type": "integer", "minimum": 2 },
        "pauseGuardian": { "$ref": "#/$defs/address" },
        "resolutionAuthority": { "$ref": "#/$defs/address" },
        "requesters": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/address" } },
        "agents": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/address" } },
        "verifiers": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/address" } },
        "confirmingVerifiers": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/address" } }
      }
    },
    "caps": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxPayoutPerTask", "maxOpenExposure", "maxOpenTasks"],
      "properties": {
        "maxPayoutPerTask": { "$ref": "#/$defs/uintString" },
        "maxOpenExposure": { "$ref": "#/$defs/uintString" },
        "maxOpenTasks": { "type": "integer", "minimum": 1 }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policyId", "requiredConfirmations", "minAvailabilityWindowSeconds"],
      "properties": {
        "policyId": { "$ref": "#/$defs/hex32" },
        "requiredConfirmations": { "type": "integer", "minimum": 1 },
        "minAvailabilityWindowSeconds": { "type": "integer", "minimum": 3600 }
      }
    },
    "custody": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slitherPassed", "readinessReportPath"],
      "properties": {
        "slitherPassed": { "type": "boolean" },
        "readinessReportPath": { "type": "string", "minLength": 1 }
      }
    },
    "docs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["boundaryDoc", "runbookDoc", "reviewDoc"],
      "properties": {
        "boundaryDoc": { "type": "string", "minLength": 1 },
        "runbookDoc": { "type": "string", "minLength": 1 },
        "reviewDoc": { "type": "string", "minLength": 1 }
      }
    }
  },
  "$defs": {
    "address": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
    "hex32": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" },
    "uintString": { "type": "string", "pattern": "^(0|[1-9][0-9]*)$" }
  }
}
