{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "flowmemory.agent_credit_score.v1",
  "title": "Agent Credit Score V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "agentId",
    "operatorId",
    "score",
    "riskBand",
    "computedAt",
    "expiresAt",
    "inputs",
    "components",
    "outputs",
    "reasonCodes"
  ],
  "properties": {
    "schemaVersion": {
      "const": "agent-credit-score/v1"
    },
    "agentId": {
      "type": "string"
    },
    "operatorId": {
      "type": "string"
    },
    "taskClass": {
      "type": "string"
    },
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1000
    },
    "riskBand": {
      "enum": [
        "A",
        "B",
        "C",
        "D",
        "E",
        "UNRATED"
      ]
    },
    "computedAt": {
      "$ref": "#/$defs/dateTime"
    },
    "expiresAt": {
      "$ref": "#/$defs/dateTime"
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true
    },
    "components": {
      "type": "object",
      "additionalProperties": true
    },
    "outputs": {
      "type": "object",
      "additionalProperties": true
    },
    "reasonCodes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "hex32": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{64}$"
    },
    "address": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{40}$"
    },
    "uintString": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)$"
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "uri": {
      "type": "string",
      "minLength": 1
    }
  }
}
