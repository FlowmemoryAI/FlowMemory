{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "flowmemory.underwriter_allocation.v1",
  "title": "Underwriter Allocation V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "allocationId",
    "poolId",
    "agentId",
    "allocatedCapacityUSDC",
    "lockedCapacityUSDC",
    "availableCapacityUSDC",
    "validFrom",
    "validUntil",
    "status"
  ],
  "properties": {
    "schemaVersion": {
      "const": "underwriter-allocation/v1"
    },
    "allocationId": {
      "type": "string"
    },
    "poolId": {
      "type": "string"
    },
    "agentId": {
      "type": "string"
    },
    "taskClass": {
      "type": "string"
    },
    "allocatedCapacityUSDC": {
      "$ref": "#/$defs/uintString"
    },
    "lockedCapacityUSDC": {
      "$ref": "#/$defs/uintString"
    },
    "availableCapacityUSDC": {
      "$ref": "#/$defs/uintString"
    },
    "validFrom": {
      "$ref": "#/$defs/dateTime"
    },
    "validUntil": {
      "$ref": "#/$defs/dateTime"
    },
    "status": {
      "enum": [
        "active",
        "paused",
        "expired",
        "slashed",
        "released"
      ]
    }
  },
  "$defs": {
    "hex32": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{64}$"
    },
    "address": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{40}$"
    },
    "uintString": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)$"
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "uri": {
      "type": "string",
      "minLength": 1
    }
  }
}
