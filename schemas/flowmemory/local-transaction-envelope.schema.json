{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "flowmemory.local_transaction_envelope.v0",
  "title": "FlowMemory Local Alpha LocalTransactionEnvelope V0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "envelopeId",
    "domain",
    "domainSeparator",
    "chainId",
    "nonce",
    "signerId",
    "signerKeyId",
    "signerRole",
    "signerRoleCode",
    "publicKey",
    "objectSchema",
    "objectType",
    "objectTypeHash",
    "objectId",
    "payloadHash",
    "issuedAtUnixMs",
    "signingDigest",
    "signature"
  ],
  "properties": {
    "schema": { "const": "flowmemory.local_transaction_envelope.v0" },
    "envelopeId": { "$ref": "#/$defs/hex32" },
    "domain": {
      "type": "string",
      "pattern": "^(flowmemory\\.local-alpha\\.v0\\.local-transaction-envelope:chain:[0-9]+|flowmemory\\.production-network\\.v0\\.transaction-envelope:profile:(local-chain|private-lan|base-8453-pilot-bridge):chain:[0-9]+)$"
    },
    "domainSeparator": { "$ref": "#/$defs/hex32" },
    "chainId": { "$ref": "#/$defs/uintString" },
    "nonce": { "$ref": "#/$defs/uintString" },
    "signerId": { "$ref": "#/$defs/hex32" },
    "signerKeyId": { "$ref": "#/$defs/hex32" },
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "networkProfile": { "enum": ["local-chain", "private-lan", "base-8453-pilot-bridge"] },
    "networkProfileHash": { "$ref": "#/$defs/hex32" },
    "signerRole": {
      "enum": [
        "operator",
        "agent",
        "verifier",
        "hardware",
        "user",
        "validator",
        "bridgeRelayer",
        "bridgeReleaseAuthority",
        "emergencyOperator"
      ]
    },
    "signerRoleCode": { "type": "integer", "minimum": 1, "maximum": 255 },
    "publicKey": { "type": "string", "pattern": "^0x([0-9a-fA-F]{66}|[0-9a-fA-F]{130})$" },
    "publicKeyEncoding": { "const": "secp256k1-compressed-hex" },
    "signerAddress": { "$ref": "#/$defs/address" },
    "objectSchema": { "type": "string", "pattern": "^(flowmemory|flowmemory)\\.[a-z_]+\\.v0$" },
    "objectType": {
      "enum": [
        "agent_account",
        "model_passport",
        "work_receipt",
        "artifact_availability_proof",
        "verifier_module",
        "verifier_report",
        "memory_cell",
        "challenge",
        "finality_receipt",
        "bridge_deposit",
        "bridge_credit",
        "bridge_withdrawal",
        "local_balance_record",
        "product_transfer",
        "product_token_launch",
        "product_pool_create",
        "product_add_liquidity",
        "product_remove_liquidity",
        "product_swap",
        "product_bridge_credit_ack",
        "bridge_withdrawal_intent",
        "pilot_bridge_credit_ack",
        "pilot_withdrawal_intent",
        "pilot_release_evidence",
        "pilot_emergency_control",
        "hardware_signal_envelope",
        "control_plane_provenance_response"
      ]
    },
    "payloadType": { "type": "string", "pattern": "^[a-z0-9_\\-]+$" },
    "payloadTypeHash": { "$ref": "#/$defs/hex32" },
    "objectTypeHash": { "$ref": "#/$defs/hex32" },
    "objectId": { "$ref": "#/$defs/hex32" },
    "payloadHash": { "$ref": "#/$defs/hex32" },
    "issuedAtUnixMs": { "$ref": "#/$defs/uintString" },
    "expiresAtUnixMs": { "$ref": "#/$defs/uintString" },
    "localExecutionCost": { "type": "object" },
    "localExecutionCostHash": { "$ref": "#/$defs/hex32" },
    "fee": { "type": "object" },
    "feeHash": { "$ref": "#/$defs/hex32" },
    "signatureAlgorithm": { "enum": ["secp256k1-keccak256-eip712-local-v0"] },
    "signatureAlgorithmHash": { "$ref": "#/$defs/hex32" },
    "signingDigest": { "$ref": "#/$defs/hex32" },
    "signature": { "type": "string", "pattern": "^0x[0-9a-fA-F]{128}$" },
    "transactionId": { "$ref": "#/$defs/hex32" }
  },
  "$defs": {
    "address": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
    "hex32": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" },
    "uintString": { "type": "string", "pattern": "^[0-9]+$" }
  }
}
