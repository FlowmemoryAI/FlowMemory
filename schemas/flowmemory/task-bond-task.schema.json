{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "flowmemory.task_bond_task.v1",
  "title": "FlowMemory TaskBond Task V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "taskId",
    "rootfieldId",
    "policyId",
    "requester",
    "agent",
    "verifier",
    "termsHash",
    "payout",
    "agentBond",
    "verifierFee",
    "requesterCancelBond",
    "disputeBond",
    "requiredConfirmations",
    "confirmedVerifierCount",
    "status",
    "openedAt",
    "acceptedAt",
    "submissionDeadline",
    "challengeDeadline",
    "flowPulseIds"
  ],
  "properties": {
    "schema": { "const": "flowmemory.task_bond_task.v1" },
    "taskId": { "$ref": "#/$defs/hex32" },
    "rootfieldId": { "$ref": "#/$defs/hex32" },
    "policyId": { "$ref": "#/$defs/hex32" },
    "requester": { "$ref": "#/$defs/address" },
    "agent": { "$ref": "#/$defs/address" },
    "verifier": { "$ref": "#/$defs/address" },
    "termsHash": { "$ref": "#/$defs/hex32" },
    "payout": { "$ref": "#/$defs/uintString" },
    "agentBond": { "$ref": "#/$defs/uintString" },
    "verifierFee": { "$ref": "#/$defs/uintString" },
    "requesterCancelBond": { "$ref": "#/$defs/uintString" },
    "disputeBond": { "$ref": "#/$defs/uintString" },
    "requiredConfirmations": { "type": "integer", "minimum": 0 },
    "confirmedVerifierCount": { "type": "integer", "minimum": 0 },
    "status": {
      "enum": ["open", "accepted", "started", "evidence_committed", "verified", "failed", "challenged", "settled", "refunded", "slashed", "unsupported", "reorged"]
    },
    "openedAt": { "type": "string", "format": "date-time" },
    "acceptedAt": { "type": "string", "format": "date-time" },
    "submissionDeadline": { "type": "string", "format": "date-time" },
    "challengeDeadline": { "type": "string", "format": "date-time" },
    "flowPulseIds": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/hex32" }
    }
  },
  "$defs": {
    "hex32": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" },
    "address": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
    "uintString": { "type": "string", "pattern": "^(0|[1-9][0-9]*)$" }
  }
}
