{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "flowmemory.underwriter_pool.v1",
  "title": "Underwriter Pool V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "poolId",
    "poolType",
    "status",
    "operatorId",
    "asset",
    "scope",
    "capacity",
    "economics",
    "lossHistory",
    "timestamps"
  ],
  "properties": {
    "schemaVersion": {
      "const": "underwriter-pool/v1"
    },
    "poolId": {
      "type": "string"
    },
    "poolType": {
      "enum": [
        "stake_capacity_pool",
        "usdc_recourse_pool"
      ]
    },
    "status": {
      "enum": [
        "draft",
        "active",
        "paused",
        "closed"
      ]
    },
    "operatorId": {
      "type": "string"
    },
    "asset": {
      "type": "object"
    },
    "scope": {
      "type": "object"
    },
    "capacity": {
      "type": "object"
    },
    "economics": {
      "type": "object"
    },
    "lossHistory": {
      "type": "object"
    },
    "timestamps": {
      "type": "object"
    }
  },
  "$defs": {
    "hex32": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{64}$"
    },
    "address": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{40}$"
    },
    "uintString": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)$"
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "uri": {
      "type": "string",
      "minLength": 1
    }
  }
}
