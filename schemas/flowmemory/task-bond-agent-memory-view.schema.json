{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "flowmemory.task_bond_agent_memory_view.v1",
  "title": "FlowMemory TaskBond AgentMemoryView V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "viewId",
    "agent",
    "rootfieldId",
    "latestTaskId",
    "taskIds",
    "verifiedTaskCount",
    "failedTaskCount",
    "slashedTaskCount",
    "totalPayoutEarned",
    "totalBondAtRisk",
    "reputationScore",
    "limitations"
  ],
  "properties": {
    "schema": { "const": "flowmemory.task_bond_agent_memory_view.v1" },
    "viewId": { "$ref": "#/$defs/hex32" },
    "agent": { "$ref": "#/$defs/address" },
    "rootfieldId": { "$ref": "#/$defs/hex32" },
    "latestTaskId": { "$ref": "#/$defs/hex32" },
    "taskIds": {
      "type": "array",
      "items": { "$ref": "#/$defs/hex32" }
    },
    "verifiedTaskCount": { "type": "integer", "minimum": 0 },
    "failedTaskCount": { "type": "integer", "minimum": 0 },
    "slashedTaskCount": { "type": "integer", "minimum": 0 },
    "totalPayoutEarned": { "$ref": "#/$defs/uintString" },
    "totalBondAtRisk": { "$ref": "#/$defs/uintString" },
    "reputationScore": { "type": "number" },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "hex32": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" },
    "address": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
    "uintString": { "type": "string", "pattern": "^(0|[1-9][0-9]*)$" }
  }
}
