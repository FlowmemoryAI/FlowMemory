{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "flowmemory.a2a_agent_bonds_extension.v1",
  "title": "A2A Agent Bonds Extension V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "uri",
    "description",
    "required",
    "params"
  ],
  "properties": {
    "uri": {
      "const": "https://flowmemory.ai/a2a/extensions/agent-bonds/v1"
    },
    "description": {
      "type": "string"
    },
    "required": {
      "type": "boolean"
    },
    "params": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "passportUrl",
        "envelopeSchemaUrl",
        "receiptSchemaUrl",
        "supportedTaskClasses",
        "settlement",
        "bonding",
        "verification"
      ],
      "properties": {
        "passportUrl": {
          "type": "string"
        },
        "envelopeSchemaUrl": {
          "type": "string"
        },
        "receiptSchemaUrl": {
          "type": "string"
        },
        "supportedTaskClasses": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "settlement": {
          "type": "object"
        },
        "bonding": {
          "type": "object"
        },
        "verification": {
          "type": "object"
        },
        "x402": {
          "type": "object"
        }
      }
    }
  },
  "$defs": {
    "hex32": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{64}$"
    },
    "address": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{40}$"
    },
    "uintString": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)$"
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "uri": {
      "type": "string",
      "minLength": 1
    }
  }
}
