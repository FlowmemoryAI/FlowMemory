{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "flowmemory.underwriter_loss_event.v1",
  "title": "Underwriter Loss Event V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "lossEventId",
    "poolId",
    "allocationId",
    "taskId",
    "receiptId",
    "reason",
    "amountSlashed",
    "asset",
    "waterfall",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "underwriter-loss-event/v1"
    },
    "lossEventId": {
      "type": "string"
    },
    "poolId": {
      "type": "string"
    },
    "allocationId": {
      "type": "string"
    },
    "taskId": {
      "type": "string"
    },
    "receiptId": {
      "type": "string"
    },
    "reason": {
      "enum": [
        "agent_invalid_submission",
        "agent_timeout",
        "policy_violation",
        "verifier_error",
        "manual_resolution"
      ]
    },
    "amountSlashed": {
      "$ref": "#/$defs/uintString"
    },
    "asset": {
      "type": "string"
    },
    "waterfall": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "createdAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "$defs": {
    "hex32": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{64}$"
    },
    "address": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{40}$"
    },
    "uintString": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)$"
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "uri": {
      "type": "string",
      "minLength": 1
    }
  }
}
