{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flowmemory.local/schemas/flowmemory/bridge-observation.schema.json",
  "title": "FlowChainBridgeDepositObservation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "observationId",
    "replayKey",
    "observedAt",
    "mode",
    "productionReady",
    "deposit",
    "guardrails"
  ],
  "properties": {
    "schema": { "const": "flowmemory.bridge_deposit_observation.v0" },
    "observationId": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" },
    "replayKey": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" },
    "observedAt": { "type": "string" },
    "mode": { "type": "string", "enum": ["mock", "local-anvil", "base-sepolia", "base-mainnet-canary"] },
    "productionReady": { "const": false },
    "deposit": { "$ref": "bridge-deposit.schema.json" },
    "guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": ["explicitChainId", "explicitContract", "explicitBlockRange", "noSecrets"],
      "properties": {
        "explicitChainId": { "type": "boolean" },
        "explicitContract": { "type": "boolean" },
        "explicitBlockRange": { "type": "boolean" },
        "noSecrets": { "type": "boolean" },
        "maxUsd": { "type": "number", "maximum": 25 }
      }
    }
  }
}
