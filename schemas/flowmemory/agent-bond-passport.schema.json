{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "flowmemory.agent_bond_passport.v1",
  "title": "FlowMemory Agent Bond Passport V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "passportId",
    "agentId",
    "operatorId",
    "displayName",
    "status",
    "chain",
    "wallets",
    "contracts",
    "stake",
    "capacity",
    "capabilities",
    "reputation",
    "verification",
    "integrations",
    "timestamps"
  ],
  "properties": {
    "schemaVersion": {
      "const": "agent-bond-passport/v1"
    },
    "passportId": {
      "type": "string",
      "minLength": 1
    },
    "agentId": {
      "type": "string",
      "minLength": 1
    },
    "operatorId": {
      "type": "string",
      "minLength": 1
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "status": {
      "enum": [
        "active",
        "paused",
        "jailed",
        "revoked",
        "draft"
      ]
    },
    "chain": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "chainId",
        "caip2",
        "name"
      ],
      "properties": {
        "chainId": {
          "type": "integer",
          "minimum": 1
        },
        "caip2": {
          "type": "string",
          "pattern": "^eip155:[0-9]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "wallets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "settlementWallet": {
          "$ref": "#/$defs/address"
        },
        "stakeWallet": {
          "$ref": "#/$defs/address"
        },
        "taskWallet": {
          "$ref": "#/$defs/address"
        },
        "signerWallet": {
          "$ref": "#/$defs/address"
        }
      }
    },
    "contracts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "manager": {
          "$ref": "#/$defs/address"
        },
        "escrow": {
          "$ref": "#/$defs/address"
        },
        "stakeRegistry": {
          "$ref": "#/$defs/address"
        },
        "policyRegistry": {
          "$ref": "#/$defs/address"
        },
        "passportRegistry": {
          "$ref": "#/$defs/address"
        },
        "receiptRegistry": {
          "$ref": "#/$defs/address"
        }
      }
    },
    "stake": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stakeToken": {
          "$ref": "#/$defs/address"
        },
        "minimumAgentStake": {
          "$ref": "#/$defs/uintString"
        },
        "currentAgentStake": {
          "$ref": "#/$defs/uintString"
        },
        "slashableStake": {
          "$ref": "#/$defs/uintString"
        },
        "stakeCapacityUSDC": {
          "$ref": "#/$defs/uintString"
        }
      }
    },
    "capacity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maxTaskPayoutUSDC",
        "maxOpenExposureUSDC",
        "currentOpenExposureUSDC",
        "maxOpenTasks",
        "currentOpenTasks"
      ],
      "properties": {
        "maxTaskPayoutUSDC": {
          "$ref": "#/$defs/uintString"
        },
        "maxOpenExposureUSDC": {
          "$ref": "#/$defs/uintString"
        },
        "currentOpenExposureUSDC": {
          "$ref": "#/$defs/uintString"
        },
        "maxOpenTasks": {
          "type": "integer",
          "minimum": 0
        },
        "currentOpenTasks": {
          "type": "integer",
          "minimum": 0
        },
        "riskBand": {
          "enum": [
            "A",
            "B",
            "C",
            "D",
            "E",
            "UNRATED"
          ]
        }
      }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "taskClass",
          "title",
          "description",
          "objectiveOnly",
          "supportedEvidenceSchemas",
          "supportedPolicyIds",
          "maxPayoutUSDC",
          "maxBondUSDC"
        ],
        "properties": {
          "taskClass": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "objectiveOnly": {
            "type": "boolean"
          },
          "supportedEvidenceSchemas": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "supportedPolicyIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "maxPayoutUSDC": {
            "$ref": "#/$defs/uintString"
          },
          "maxBondUSDC": {
            "$ref": "#/$defs/uintString"
          },
          "requiresHumanOversight": {
            "type": "boolean"
          }
        }
      }
    },
    "reputation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "completedTasks",
        "settledTasks",
        "challengedTasks",
        "upheldChallenges",
        "slashedTasks",
        "unsupportedTasks",
        "timeoutTasks",
        "totalSettledUSDC",
        "totalSlashedUSDC",
        "latestReceiptIds"
      ],
      "properties": {
        "completedTasks": {
          "type": "integer",
          "minimum": 0
        },
        "settledTasks": {
          "type": "integer",
          "minimum": 0
        },
        "challengedTasks": {
          "type": "integer",
          "minimum": 0
        },
        "upheldChallenges": {
          "type": "integer",
          "minimum": 0
        },
        "slashedTasks": {
          "type": "integer",
          "minimum": 0
        },
        "unsupportedTasks": {
          "type": "integer",
          "minimum": 0
        },
        "timeoutTasks": {
          "type": "integer",
          "minimum": 0
        },
        "totalSettledUSDC": {
          "$ref": "#/$defs/uintString"
        },
        "totalSlashedUSDC": {
          "$ref": "#/$defs/uintString"
        },
        "latestReceiptIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verifierIds",
        "confirmingVerifierRequired"
      ],
      "properties": {
        "verifierIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confirmingVerifierRequired": {
          "type": "boolean"
        },
        "verifierDiversityScore": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "integrations": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "a2a": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "supportsFlowMemoryExtension"
          ],
          "properties": {
            "agentCardUrl": {
              "type": "string"
            },
            "extendedAgentCardUrl": {
              "type": "string"
            },
            "supportsFlowMemoryExtension": {
              "type": "boolean"
            }
          }
        },
        "mcp": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "tools",
            "resources"
          ],
          "properties": {
            "serverUrl": {
              "type": "string"
            },
            "tools": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "resources": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "x402": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "acceptsX402",
            "supportedNetworks",
            "supportedAssets"
          ],
          "properties": {
            "acceptsX402": {
              "type": "boolean"
            },
            "paymentEndpoint": {
              "type": "string"
            },
            "supportedNetworks": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "supportedAssets": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "timestamps": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "createdAt": {
          "$ref": "#/$defs/dateTime"
        },
        "updatedAt": {
          "$ref": "#/$defs/dateTime"
        },
        "expiresAt": {
          "$ref": "#/$defs/dateTime"
        }
      }
    },
    "signatures": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "signer",
          "algorithm",
          "signature",
          "signedAt"
        ],
        "properties": {
          "signer": {
            "type": "string"
          },
          "algorithm": {
            "type": "string"
          },
          "signature": {
            "type": "string"
          },
          "signedAt": {
            "$ref": "#/$defs/dateTime"
          }
        }
      }
    }
  },
  "$defs": {
    "hex32": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{64}$"
    },
    "address": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{40}$"
    },
    "uintString": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)$"
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "uri": {
      "type": "string",
      "minLength": 1
    }
  }
}
