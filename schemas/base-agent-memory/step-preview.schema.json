{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "flowmemory.base_agent_memory.step_preview.v1",
  "title": "Base Agent Memory StepPreview V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "previewHash", "agentId", "sequence", "observationRoot", "action", "toolId", "target", "selector", "callDataHash", "memoryDeltaRoot", "reasonCode", "maxValue"],
  "properties": {
    "schema": { "const": "flowmemory.base_agent_memory.step_preview.v1" },
    "previewHash": { "$ref": "#/$defs/hex32" },
    "agentId": { "$ref": "#/$defs/hex32" },
    "sequence": { "type": "string", "pattern": "^[0-9]+$" },
    "observationRoot": { "$ref": "#/$defs/hex32" },
    "action": { "enum": ["NOOP", "ESCALATE", "ACCEPT_TASK", "REJECT_TASK", "COMMIT_EVIDENCE", "UPDATE_MEMORY_ONLY", "PAUSE_SELF"] },
    "toolId": { "$ref": "#/$defs/hex32" },
    "target": { "$ref": "#/$defs/address" },
    "selector": { "type": "string", "pattern": "^0x[0-9a-fA-F]{8}$" },
    "callDataHash": { "$ref": "#/$defs/hex32" },
    "memoryDeltaRoot": { "$ref": "#/$defs/hex32" },
    "reasonCode": { "type": "string" },
    "maxValue": { "type": "string", "pattern": "^[0-9]+$" }
  },
  "$defs": {
    "hex32": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" },
    "address": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" }
  }
}
