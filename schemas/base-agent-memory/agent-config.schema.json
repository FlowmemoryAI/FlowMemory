{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "flowmemory.base_agent_memory.agent_config.v1",
  "title": "Base Agent Memory AgentConfig V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "agentId", "owner", "rootfieldId", "kernelAddress", "kernelClass", "policyRoot", "toolAllowlistRoot", "latestMemoryRoot", "sequence", "autonomyLevel", "status"],
  "properties": {
    "schema": { "const": "flowmemory.base_agent_memory.agent_config.v1" },
    "agentId": { "$ref": "#/$defs/hex32" },
    "owner": { "$ref": "#/$defs/address" },
    "rootfieldId": { "$ref": "#/$defs/hex32" },
    "kernelAddress": { "$ref": "#/$defs/address" },
    "kernelClass": { "$ref": "#/$defs/hex32" },
    "policyRoot": { "$ref": "#/$defs/hex32" },
    "toolAllowlistRoot": { "$ref": "#/$defs/hex32" },
    "latestMemoryRoot": { "$ref": "#/$defs/hex32" },
    "sequence": { "type": "string", "pattern": "^[0-9]+$" },
    "autonomyLevel": { "type": "integer", "minimum": 0 },
    "status": { "enum": ["active", "paused", "finalized", "failed"] }
  },
  "$defs": {
    "hex32": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" },
    "address": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" }
  }
}
