{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "flowmemory.base_agent_memory.task_observation.v1",
  "title": "Base Agent Memory TaskObservation V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "observationRoot", "observationId", "agentId", "taskContract", "taskId", "taskKind", "taskKindName", "evidenceRequirement", "evidenceRequirementName", "rewardToken", "rewardAmount", "deadlineBlock", "taskStatus", "recentFailureCount", "humanReviewRequired"],
  "properties": {
    "schema": { "const": "flowmemory.base_agent_memory.task_observation.v1" },
    "observationRoot": { "$ref": "#/$defs/hex32" },
    "observationId": { "$ref": "#/$defs/hex32" },
    "agentId": { "$ref": "#/$defs/hex32" },
    "taskContract": { "$ref": "#/$defs/address" },
    "taskId": { "$ref": "#/$defs/hex32" },
    "taskKind": { "$ref": "#/$defs/hex32" },
    "taskKindName": { "const": "docs-review" },
    "evidenceRequirement": { "$ref": "#/$defs/hex32" },
    "evidenceRequirementName": { "const": "public" },
    "rewardToken": { "$ref": "#/$defs/address" },
    "rewardAmount": { "type": "string", "pattern": "^[0-9]+$" },
    "deadlineBlock": { "type": "string", "pattern": "^[0-9]+$" },
    "taskStatus": { "const": "open" },
    "recentFailureCount": { "type": "integer", "minimum": 0 },
    "humanReviewRequired": { "type": "boolean" }
  },
  "$defs": {
    "hex32": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" },
    "address": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" }
  }
}
