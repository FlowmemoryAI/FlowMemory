{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "flowmemory.base_agent_memory.memory_delta.v1",
  "title": "Base Agent Memory MemoryDelta V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "memoryDeltaId", "agentId", "sequence", "parentMemoryRoot", "deltaRoot", "newMemoryRoot", "readSetRoot", "writeSetRoot", "actionReceiptId", "sourceObservationId", "memoryCellIds", "status"],
  "properties": {
    "schema": { "const": "flowmemory.base_agent_memory.memory_delta.v1" },
    "memoryDeltaId": { "$ref": "#/$defs/hex32" },
    "agentId": { "$ref": "#/$defs/hex32" },
    "sequence": { "type": "string", "pattern": "^[0-9]+$" },
    "parentMemoryRoot": { "$ref": "#/$defs/hex32" },
    "deltaRoot": { "$ref": "#/$defs/hex32" },
    "newMemoryRoot": { "$ref": "#/$defs/hex32" },
    "readSetRoot": { "$ref": "#/$defs/hex32" },
    "writeSetRoot": { "$ref": "#/$defs/hex32" },
    "actionReceiptId": { "$ref": "#/$defs/hex32" },
    "sourceObservationId": { "$ref": "#/$defs/hex32" },
    "memoryCellIds": { "type": "array", "items": { "$ref": "#/$defs/hex32" } },
    "status": { "$ref": "#/$defs/status" }
  },
  "$defs": {
    "hex32": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" },
    "status": { "enum": ["pending", "verified", "failed", "unresolved", "unsupported", "reorged"] }
  }
}
