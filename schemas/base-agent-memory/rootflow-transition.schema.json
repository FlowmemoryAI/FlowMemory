{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "flowmemory.base_agent_memory.rootflow_transition.v1",
  "title": "Base Agent Memory RootflowTransition V1",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema", "transitionId", "agentId", "rootfieldId", "sourceObservationId", "parentRoot", "newRoot", "actionReceiptId", "verifierReportId", "status", "sequence", "pulseId", "contractEventRef"],
  "properties": {
    "schema": { "const": "flowmemory.base_agent_memory.rootflow_transition.v1" },
    "transitionId": { "$ref": "#/$defs/hex32" },
    "agentId": { "$ref": "#/$defs/hex32" },
    "rootfieldId": { "$ref": "#/$defs/hex32" },
    "sourceObservationId": { "$ref": "#/$defs/hex32" },
    "parentRoot": { "$ref": "#/$defs/hex32" },
    "newRoot": { "$ref": "#/$defs/hex32" },
    "actionReceiptId": { "$ref": "#/$defs/hex32" },
    "verifierReportId": { "$ref": "#/$defs/hex32" },
    "status": { "$ref": "#/$defs/status" },
    "sequence": { "type": "string", "pattern": "^[0-9]+$" },
    "pulseId": { "$ref": "#/$defs/hex32" },
    "contractEventRef": { "type": "object" }
  },
  "$defs": {
    "hex32": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" },
    "status": { "enum": ["pending", "verified", "failed", "unresolved", "unsupported", "reorged"] }
  }
}
