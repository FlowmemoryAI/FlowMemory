{
  "appId": "ai.flowmemory.flowchain.wallet",
  "productName": "FlowMemory Operator",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "electron/**/*",
    "package.json"
  ],
  "asar": true,
  "mac": {
    "category": "public.app-category.finance",
    "target": [
      "dmg",
      "zip"
    ],
    "identity": null
  },
  "win": {
    "signAndEditExecutable": false,
    "target": [
      "nsis",
      "zip"
    ]
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "FlowMemory Operator"
  },
  "linux": {
    "category": "Finance",
    "target": [
      "AppImage",
      "zip"
    ]
  }
}
