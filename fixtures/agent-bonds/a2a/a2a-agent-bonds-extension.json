{
  "uri": "https://flowmemory.ai/a2a/extensions/agent-bonds/v1",
  "description": "FlowMemory Agent Bonds passport/envelope/receipt extension for bonded work discovery.",
  "required": false,
  "params": {
    "passportUrl": "https://example.invalid/agent-bonds/passports/agent_code_001",
    "envelopeSchemaUrl": "https://flowmemory.ai/schemas/bonded-task-envelope/v1",
    "receiptSchemaUrl": "https://flowmemory.ai/schemas/bonded-execution-receipt/v1",
    "supportedTaskClasses": [
      "code.patch"
    ],
    "settlement": {
      "chainId": 8453,
      "caip2": "eip155:8453",
